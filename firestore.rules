rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /rooms/{roomId} {
      // Any authenticated user can create or READ rooms
      // (READ is required so a user arriving via share link can see the room and join)
      allow create: if request.auth != null;
      allow read: if request.auth != null;

      // Members can do any update; non-members can only add themselves to the members array
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (
          request.auth.uid in request.resource.data.members &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        )
      );

      // Members can read and write messages
      match /messages/{msgId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
      }
    }
  }
}
